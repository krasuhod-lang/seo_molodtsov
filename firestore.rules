rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Контент и офферы публично читаемы (нужно мобильному приложению),
    // менять может только аутентифицированный администратор.
    match /content/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /offers/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
